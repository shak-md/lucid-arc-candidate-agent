# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Workday tenant
WORKDAY_TENANT_URL=https://wd2-impl-services1.workday.com/ccx/service/your_tenant

# Set to "basic" for ISU auth or "oauth2" for OAuth 2.0
WORKDAY_AUTH_MODE=basic

# ISU basic auth (used when WORKDAY_AUTH_MODE=basic)
WORKDAY_ISU_USERNAME=your_isu_username
WORKDAY_ISU_PASSWORD=your_isu_password

# OAuth 2.0 (used when WORKDAY_AUTH_MODE=oauth2)
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
WORKDAY_TOKEN_URL=

# App
AUDIT_LOG_DB_URL=sqlite:///./audit.db
POOL_CACHE_TTL=300
